# Copy this file to .env and fill in your keys
# None of the keys are required — the app degrades gracefully without them

# VirusTotal API v3 — enables live file hash lookups
# Get yours at: https://www.virustotal.com/gui/user/apikey
VT_API_KEY=

# AbuseIPDB — adds abuse confidence scores to IPs
# Get yours at: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# ipdata.co — adds datacenter/proxy/Tor threat flags
# Get yours at: https://ipdata.co/
IPDATA_API_KEY=

# Azure app registration — for syncing live alerts from Microsoft Defender
# Create one at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
